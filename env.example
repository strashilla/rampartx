# Подключение к MySQL (БД rampartx).
# Скопируйте этот файл в .env.local и подставьте свои данные.

# Формат: mysql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД
DATABASE_URL="mysql://root:ВАШ_ПАРОЛЬ@localhost:3306/rampartx"

# Примеры:
# Без пароля: mysql://root:@localhost:3306/rampartx
# С паролем:  mysql://root:password@localhost:3306/rampartx
