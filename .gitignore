# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================
# ЗАВИСИМОСТИ
# ============================================
/node_modules
/.pnp
.pnp.js

# ============================================
# NEXT.JS
# ============================================
/.next/
/out/
next-env.d.ts

# ============================================
# ПРОДАКШЕН СБОРКА
# ============================================
/build

# ============================================
# ЛОГИ И ОТЛАДКА
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
# ============================================
# Игнорируем все .env файлы, кроме примеров
.env*
!.env.example
# Исключаем .env.example из игнора (шаблон)
!.env.example
# Но игнорируем реальные файлы с секретами
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ============================================
# VERCEL
# ============================================
.vercel

# ============================================
# TYPESCRIPT
# ============================================
*.tsbuildinfo
tsconfig.tsbuildinfo

# ============================================
# IDE И РЕДАКТОРЫ
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ============================================
# БАЗЫ ДАННЫХ (локальные)
# ============================================
# Игнорируем все SQL файлы, кроме rampartx.sql
*.sql
!rampartx.sql
*.db
*.sqlite
*.sqlite3

# ============================================
# ВРЕМЕННЫЕ ФАЙЛЫ
# ============================================
*.tmp
*.temp
.cache/

# ============================================
# ZIP АРХИВЫ
# ============================================
*.zip
*.rar
*.7z
*.tar
*.gz